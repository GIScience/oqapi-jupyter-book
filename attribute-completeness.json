jNGVC9N"}],"key":"beqtnfL82N"},{"type":"listItem","spread":true,"position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Der Schwellenwert zur Einschätzung der Vollständigkeit ist für jedes Attribute der Gleiche. Dieser Schwellenwert ist jedoch vom Anwendungsfall abhängig.","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"key":"UruyWdd13G"}],"key":"HkDiZ6GPCG"}],"key":"hX3An8JeID"}],"key":"jk4uehwwkB"}],"key":"n0uT2YuGaz"},{"type":"heading","depth":2,"position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"text","value":"Beispiele","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"hop7adGKGD"}],"identifier":"beispiele","label":"Beispiele","html_id":"beispiele","implicit":true,"key":"J4DJ1KIah4"},{"type":"paragraph","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"text","value":"In folgendem Beispiel sehen wir wie wichtig es ist, das richtige Thema auszuwählen. Wir wollen die Attributvollständigkeit der Straßennamen für die Frankfurter Innenstadt herausfinden.","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"i0roZDGjXL"}],"key":"g1uPoPOJgW"},{"type":"paragraph","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"children":[{"type":"text","value":"Auf dieser Abbildung sehen wir das Ergebnis für das Thema ","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"key":"UBeNzQU33k"},{"type":"emphasis","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"children":[{"type":"text","value":"Straßen(alle highways)","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"key":"lrp0EU4Bwk"}],"key":"YBqPyZydNG"},{"type":"text","value":". Knapp 40% ist eine mittelmäßige Vollständigkeit und ein überraschendes Ergebnis für eine deutsche Großstadt. Spätestens jetzt muss uns auffallen, dass hier etwas eventuell nicht ganz stimmt. Das Thema ","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"key":"Vy4QSNCc9p"},{"type":"emphasis","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"children":[{"type":"text","value":"Straßen(alle highways)","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"key":"ocPGlRzklW"}],"key":"On0xSHApPW"},{"type":"text","value":" beinhaltet nicht nur von Autos befahrbare Straßen, sondern sämtliche Wege für motorisierten Verkehr sowie Rad- und Fußwege. Da viele Rad- und Fußwege keinen expliziten Namen haben, ist das Ergebnis der Abfrage nur knapp 40%.","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"key":"cAdDBC6vIj"}],"key":"Dx8Q8kgFWk"},{"type":"div","children":[{"type":"image","url":"/oqapi-jupyter-book/build/attributvollständigk-357101b2c6e29e3e7aa005b1d7da6607.png","key":"qTvDJ8lP92","urlSource":"../../abbildungen/attributvollständigkeit_frankfurt.png"}],"key":"tGPsNMGLWx"},{"type":"paragraph","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"children":[{"type":"text","value":"Wenn wir uns nur für die Straßennamen der Straßen für motorisierten Verkehr interessieren, entscheiden wir uns für das Thema ","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"key":"fIreGK7Ffq"},{"type":"emphasis","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"children":[{"type":"text","value":"Straßen(Autos)","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"key":"GlbImQCYpS"}],"key":"oaW5vo9zS6"},{"type":"text","value":". In der nächsten Abbildung sehen wir, dass wir nun für dasselbe Untersuchungsgebiet eine hohe Vollständigkeit erhalten.","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"key":"haubpB8oPS"}],"key":"E18rkI96B6"},{"type":"div","children":[{"type":"image","url":"/oqapi-jupyter-book/build/at