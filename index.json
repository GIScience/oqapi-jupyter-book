{"version":3,"kind":"Article","sha256":"ae6f8f7dd2292eaa7b108f0d9c49c1e8791071d0b20e2d4ded3e0b30a8e4fdf8","slug":"index","location":"/intro.md","dependencies":[],"frontmatter":{"title":"OQAPI Jupyter Book","content_includes_title":false,"exports":[{"format":"md","filename":"intro.md","url":"/oqapi-jupyter-book/build/intro-373be919bead16256ccad4a8773734b0.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Welcome to the ohsome Dashboard tutorial. Here you find explanations and user guidlines for all of our quality indicators for OSM data.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"kL01Rke1z3"}],"key":"VB90j8wuGU"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"OpenStreetMap is a rich source of user-generated, freely available geospatial data for many applications. However, varying data quality and a lack of standardization can make it challenging to use. We developed the ohsome Dashboard for you to assess OSM data quality globally or for specific areas and helping you determine if it meets your project needs.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"JVmOFYInkv"}],"key":"gem70S8l15"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"The ohsome dashboard enables analysis of OpenStreetMap data with full version history, no programming required. It generates statistics and visualizes them directly, with customizable filters and groupings by tags, types, region, and time. The ohsome Quality API (OQAPI) provides access to OSM data quality information for specific regions and use cases.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"fFpV8ZWB7Z"}],"key":"skZTLQ8USA"},{"type":"heading","depth":2,"position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Quality Dimensions","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"L8jmWf2oOL"}],"identifier":"quality-dimensions","label":"Quality Dimensions","html_id":"quality-dimensions","implicit":true,"key":"fqcyQSmTL5"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":10,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Completeness","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"l5fqQfZnhp"}],"key":"Bzh4rQSdZm"}],"key":"LtvaBJwn23"},{"type":"listItem","spread":true,"position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Currentness","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"gKc7Fps5Ag"}],"key":"kNuaaYZwAM"}],"key":"UgnhVewWg4"},{"type":"listItem","spread":true,"position":{"start":{"line":12,"column":1},"end":{"line":13,"column":1}},"children":[],"key":"ux45HUgnrW"}],"key":"tZ8F8HTlHZ"}],"key":"Aebr4y666l"}],"key":"KrSX7vzp7t"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"next":{"title":"Attribute Completeness","url":"/attribute-completeness","group":"Content"}}},"domain":"http://localhost:3000"}