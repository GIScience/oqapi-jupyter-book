:48,"column":1}},"key":"RyaGV212N9"},{"type":"cite","url":"https://doi.org/10.1016/j.jag.2017.07.014","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"children":[{"type":"text","value":"Schultz ","key":"bSmouyev9J"},{"type":"emphasis","children":[{"type":"text","value":"et al.","key":"R9799kA0Dg"}],"key":"CfBtxptjSQ"},{"type":"text","value":" (2017)","key":"Nwzc9DwdQi"}],"kind":"narrative","label":"Schultz_2017","identifier":"https://doi.org/10.1016/j.jag.2017.07.014","enumerator":"1","key":"yygwiCiIxM"},{"type":"text","value":".","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"IjxcpxFqrt"}],"key":"BNHwAY4lKm"}],"key":"NOj4SsJErf"}],"key":"Ip1Of8b3k6"}],"key":"Ry5JDrRVT5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import geojson\nimport requests\nimport geopandas as gpd\nimport pandas as pd\nimport time\nfrom concurrent.futures import ThreadPoolExecutor, as_completed\nimport sys","key":"sEXmxsS7Zf"},{"type":"outputs","id":"V55I3T8CtZuRKidSd656K","children":[],"key":"zjw0cHPwuq"}],"key":"RmgOqeHqUg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"indicator = \"/land-cover-thematic-accuracy\"\ntopic = \"land-cover\"\ninput_geom_path = \"friedberg.geojson\"\noutput_geom_path = \"your_output_layer.gpkg\"\nmax_workers = 20\n\nbase_url = \"https://api.quality.ohsome.org/v1-test\"\nendpoint = \"/indicators\"\nurl = base_url + endpoint + indicator\n\ngdf = gpd.read_file(input_geom_path)\ngdf[\"result_value\"] = pd.Series([None] * len(gdf), dtype=\"float\")\ngdf[\"response_time\"] = pd.Series([None] * len(gdf), dtype=\"float\")\n\nheaders = {\"accept\": \"application/json\"}\n\ndef fetch(index, geometry):\n    bpolys = geojson.Feature(geometry=geometry)\n    bpolys_collection = geojson.FeatureCollection([bpolys])\n\n    parameters = {\n        \"topic\": topic,\n        \"bpolys\": bpolys_collection,\n    }\n    for attempt in range(5):\n        try:\n            print(f\"posting request for index {index}\")\n            startresponse = time.time()\n            response = requests.post(url, headers=headers, json=parameters, timeout=600)\n            response.raise_for_status()\n            result = response.json()\n            endresponse = time.time()\n            responsetime = endresponse - startresponse\n            value = result[\"result\"][0][\"result\"][\"value\"]\n            return index, value, responsetime\n        except requests.RequestException as e:\n            print(f\"Attempt {attempt + 1} failed at index {index}: {e}\")\n            if attempt < 3:\n                print(\"Retrying...\")\n                time.sleep(2)\n            else:\n                print(\"Max retries reached. Skipping.\")\n                return index, None, None\n\nstart = time.time()\nwith ThreadPoolExecutor(max_workers=max_workers) as executor:\n    futures = [executor.submit(fetch, i, gdf.geometry.iloc[i]) for i in range(len(gdf))]\n\n    for future in as_completed(futures):\n        index, value, responsetime = future.result()\n        gdf.at[index, \"result_value\"] = value\n        gdf.at[index, \"response_time\"] = responsetime\n        print(f\"Completed index {index}: {value}\")\n\nend = time.time()\nprint(f\"Calculation took {end - start:.2f} seconds\")\n\ngdf.to_file(output_geom_path, driver=\"GPKG\")\n","key":"J4eDD1CHOa"},{"type":"outputs","id":"vaL1fpPyblNaPH9YeaLUD","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"posting request for index 0\nCompleted index 0: 0.8424891262702325\nCalculation took 1.47 seconds\n"},"children":[],"key":"ikGtTcEFbC"}],"key":"IQi4Ov05jF"}],"key":"pXX47QcURB"}],"key":"ZLdPduq0jQ"},"references":{"cite":{"order":["Schultz_2017"],"data":{"Schultz_2017":{"label":"Schultz_2017","enumerator":"1","doi":"10.1016/j.jag.2017.07.014","html":"Schultz, M., Voss, J., Auer, M., Carter, S., & Zipf, A. (2017). Open land cover from OpenStreetMap and remote sensing. <i>International Journal of Applied Earth Observation and Geoinformation</i>, <i>63</i>, 206–213. <a target=\"_blank\" rel=\"noreferrer\" href=\"https://doi.org/10.1016/j.jag.2017.07.014\">10.1016/j.jag.2017.07.014</a>","url":"https://doi.org/10.1016/j.jag.2017.07.014"}}}},"footer":{"navigation":{"prev":{"title":"Land Cover Completeness","url":"/land-cover-completeness","group":"Content"},"next":{"title":"Mapping Saturation","url":"/mapping-saturation","group":"Content"}}},"domain":"http://localhost:3000"}