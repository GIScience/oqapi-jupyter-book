/build/landbedeck_thematisc-9fba2018664c359500718cf67e13981f.png","width":700,"key":"ncNw8XcdGy","urlSource":"../../abbildungen/landbedeck_thematisch_bonn.png"}],"key":"fzc3G67siJ"},{"type":"paragraph","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"text","value":"Wenn wir in dem Dropdown-Menü eine spezielle Landbedeckungsklasse auswählen die uns besonders interessiert, sieht das Ergebnis wie folgt aus. Hier sehen wir die thematische Genauigkeit für Grünflächen in Bonn. Falsch-Negativ, Richtig-Positiv und Falsch-Positiv sind hier jeweils zu etwa einem Drittel vorhanden. Dies zeigt uns eine geringe Übereinstimmung des OSM mit dem Corine Datensatzes im Bereich Grünflächen in Bonn.","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"ZEWXusFnXq"}],"key":"v8MI62nv15"},{"type":"div","children":[{"type":"image","url":"/oqapi-jupyter-book/build/landbedeck_thematisc-2224c7d52c1bf732d9acfc109c48d8de.png","width":700,"key":"qSdHrsChM8","urlSource":"../../abbildungen/landbedeck_thematisch_bonn_grünflächen.png"}],"key":"TvT80Ooqo1"},{"type":"paragraph","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"children":[{"type":"text","value":"Eine höhere Übereinstimmung finden wir im Kreis Euskirchen mit der Klasse Ackerland.","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"key":"ampM4lNGn0"}],"key":"sCR6W3Tjfw"},{"type":"div","children":[{"type":"image","url":"/oqapi-jupyter-book/build/landbedeck_thematisc-43380aac1e878455ed6843b9ab3b23eb.png","width":700,"key":"hLnNLHvV0d","urlSource":"../../abbildungen/landbedeck_thematisch_euskirchen_ackerland.png"}],"key":"OZSHl3SWD8"},{"type":"heading","depth":3,"position":{"start":{"line":90,"column":1},"end":{"line":90,"column":1}},"children":[{"type":"text","value":"Für diesen Indikator genutzte Literatur","position":{"start":{"line":90,"column":1},"end":{"line":90,"column":1}},"key":"CHpWDYgh6B"}],"identifier":"f-r-dies