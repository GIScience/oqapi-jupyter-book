{"version":3,"kind":"Notebook","sha256":"ec3e81c5c86915af74b33d1675943eb6b38127b08b09f7026cd2fa4f85fa4ff0","slug":"mapping-saturation","location":"/content/mapping_saturation.ipynb","dependencies":[],"frontmatter":{"title":"Mapping Saturation","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"numbering":{"title":{"offset":1}},"thumbnail":"/oqapi-jupyter-book/build/mapping_sat_ansbach-de1109fba508d8b2c95f64cf52e371b4.png","exports":[{"format":"ipynb","filename":"mapping_saturation.ipynb","url":"/oqapi-jupyter-book/build/mapping_saturation-ed175d4cb6cc11f2c8665f01ec1347cc.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"The Mapping Saturation Indicator provides (alongside the completeness indicators) a measure of completeness by analyzing how the\ngrowth of mapped features in OSM approaches a natural maximum over time.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ir3hqHpZsL"}],"key":"lAqRWPOQVl"},{"type":"heading","depth":2,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Methods and Data","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"gt3XPrySCT"}],"identifier":"methods-and-data","label":"Methods and Data","html_id":"methods-and-data","implicit":true,"key":"S4nDk4MmUV"},{"type":"paragraph","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"-> Intrinsic approach","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"WPVg4wa9I6"}],"key":"HSh4eH2qTE"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"The central premise of the mapping saturation is that each feature has a finite extent in reality. As mapping activity increases, the number or length of newly added objects per time step decreases, and the cumulative growth curve gradually saturates toward the true value.\nTo estimate this saturation level, we use the historical evolution of OSM contributions and fit non-linear regression models, to the cumulative growth curve. The workflow for the mapping saturation indicator consists of four main steps.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"wh2AHCdbRp"}],"key":"GxXmA2kTqY"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":11,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"The temporal evolution of OSM data is extracted for the selected feature class, aggregated at monthly intervals beginning in 2008.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"Ox6MZ43p33"}],"key":"wEwjVwoEiT"}],"key":"KhGEquTLTv"},{"type":"listItem","spread":true,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"The cumulative time series of mapped features is fitted with different logistic growth models using a non- linear regression approach.","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"IHMbNNAsKo"}],"key":"VQIr0LEmdG"}],"key":"hiwtdSjs1V"},{"type":"listItem","spread":true,"position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"The best-fitting model is selected based on statistical error criteria.","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"QeROXx9AEN"}],"key":"rSlF0PkS97"}],"key":"Ca3xNQQJdy"},{"type":"listItem","spread":true,"position":{"start":{"line":14,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"The asymptote of the fitted model is used to approximate the maximum number of mappable objects, and completeness is calculated as the integral of the actual OSM data to the fitted saturation curve over the last 3 years normalised to\na range of 0 to 1.","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"vLdzAkWabI"}],"key":"uURtyM3Xnn"}],"key":"SJ3styf4xq"}],"key":"FxesjEE4Sy"},{"type":"paragraph","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"This results in three quality steps:","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"HBDCJ9Nx1E"}],"key":"HLDsrmlRHj"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":19,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Not saturated (<0.3)","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"h7haKbmzND"}],"key":"zzZi3EnlRG"}],"key":"cRPn1DV5i6"},{"type":"listItem","spread":true,"position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Ongoing mapping (0.3 - 0.97)","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"Ha87usvlWx"}],"key":"vbAMgzQ7c2"}],"key":"zc52tATY4Q"},{"type":"listItem","spread":true,"position":{"start":{"line":21,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"High saturation (> 0.97)","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"IVYNe3dc0u"}],"key":"ap0EKbO253"}],"key":"c9Cvfu0zjO"}],"key":"a3Zh9vVY5W"},{"type":"paragraph","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"The mapping saturation result curve can be tricky to inperpret. How meaningful the result value is, also comes down to the shape of the saturation curve.","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"JjQeCZrYGo"}],"key":"n7XOZJHil5"},{"type":"paragraph","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"Here you see an example of a classic ‘good’ saturation curve. Over the years, more and more data was added over time. In the period from 2008 to 2010 the most length was mapped in a short time. Than, slowely less lenght was mapped over time, but a continuous mapping is still visible.","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"daX3JWswCo"}],"key":"IsLq5ikDlb"},{"type":"image","url":"/oqapi-jupyter-book/build/mapping_sat_ansbach-de1109fba508d8b2c95f64cf52e371b4.png","alt":"mapping_sat","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"HE7OoTzo7e","urlSource":"images/mapping_sat_ansbach.png"},{"type":"paragraph","position":{"start":{"line":30,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"In this example you see a differently shaped saturation curve. The data was added not continously and slowely saturation, but it reaccuring chunks, which makes this staircase optic.\n","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"LSRokD3T4d"},{"type":"image","url":"/oqapi-jupyter-book/build/mapping_sat_tunesien-e4ad5e83982ce24fddf0727c89becb21.png","alt":"mapping_sat","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"S8ZBa2UHHN","urlSource":"images/mapping_sat_tunesien.png"}],"key":"qzwT0Bv3T3"},{"type":"heading","depth":2,"position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"text","value":"Limitations","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"R7nlHE6hGh"}],"identifier":"limitations","label":"Limitations","html_id":"limitations","implicit":true,"key":"QQAJOkTO45"},{"type":"paragraph","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"children":[{"type":"text","value":"Informativeness varies across topics: performs better for small, discrete objects (e.g., houses) but worse for large polygons (e.g., land use), where a single abrupt mapping step can lead to low completeness.","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"kSvHIGREOk"}],"key":"CnHklwVimV"},{"type":"heading","depth":2,"position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"References","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"TlVbhtGpds"}],"identifier":"references","label":"References","html_id":"references","implicit":true,"key":"RVUnFax4Cp"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":38,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Gröchenig S et al. (2014): Digging into the history of VGI data-sets: results from a worldwide study on OpenStreetMap mapping activity (","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"JypzB7W0Uc"},{"type":"cite","url":"https://doi.org/10.1080/17489725.2014.978403","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"Gröchenig ","key":"wOnBbr6ujY"},{"type":"emphasis","children":[{"type":"text","value":"et al.","key":"UqOki7SESe"}],"key":"QS5jjraS7o"},{"type":"text","value":" (2014)","key":"LtGgnSQ2dq"}],"kind":"narrative","label":"Gr_chenig