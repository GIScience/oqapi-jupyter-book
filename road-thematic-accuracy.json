lumn":1},"end":{"line":72,"column":1}},"children":[{"type":"text","value":"oneway","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"jgZpsobJb4"}],"key":"mGSQSZAAZ7"},{"type":"tableCell","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"children":[{"type":"text","value":"FAR","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"V1WwAsCZdD"}],"key":"DcBWOwGhvG"},{"type":"tableCell","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"children":[{"type":"text","value":"Die Fahrtrichtung von Einbahnstraßen.","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"oEZ5BYY0Rw"}],"key":"IDmh9Zg9Ip"}],"key":"BDR3BRBEFU"}],"key":"QUexrBrtLF"},{"type":"heading","depth":2,"position":{"start":{"line":74,"column":1},"end":{"line":74,"column":1}},"children":[{"type":"text","value":"Ergebnisgrafik","position":{"start":{"line":74,"column":1},"end":{"line":74,"column":1}},"key":"lwweT14P6B"}],"identifier":"ergebnisgrafik","label":"Ergebnisgrafik","html_id":"ergebnisgrafik","implicit":true,"key":"MlHTha5qMC"},{"type":"paragraph","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"text","value":"Die Abbildung besteht aus ein oder zwei Balkendiagrammen. Die linke Abbildung zeigt an, wie viel Straßenlänge aller Straßen des DLMs, die mit OSM-Straßen gematchten werden konnten, das gewählte Attribut vorweisen. Dabei wird unterschieden, ob das Attribut nur im DLM, nur in OSM, in beiden oder keinem von beiden vorhanden ist. Sofern es Straßen gibt, bei denen das Attribut in beiden Datensätzen vorkommt, wird zusätzlich ein weiteres Balkendiagramm auf der rechten Seite angezeigt. Dieses zeigt, bei wie viel dieser Straßenlänge, in der das Attribut in beiden Datensätzen vorkommt, dieses Attribut übereinstimmt bzw. nicht übereinstimmt. Sofern für keine Straße das Attribut in beiden Datensätzen vorhanden ist, bleibt die rechte Seite der Abbildung leer.","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"S08boKjRdu"}],"key":"RWAgYIBrwA"},{"type":"heading","depth":2,"position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"text","value":"Beispiel","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"gHWbE5t1N9"}],"identifier":"beispiel","label":"Beispiel","html_id":"beispiel","implicit":true,"key":"f8bzF4z01a"},{"type":"paragraph","position":{"start":{"line":80,"column":1},"end":{"line":83,"column":1}},"children":[{"type":"text","value":"In dieser Beispielabbildung wurde die Übereinstimmung des Straßenattributs ","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"key":"cmLMG9Axf9"},{"type":"emphasis","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"children":[{"type":"text","value":"Name","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"key":"RTtd0ukLWK"}],"key":"pbGEjKsUYy"},{"type":"text","value":" überprüft.\nDie blauen Balken zeigen das Vorhandensein des Attributs in jedem Datensatz (OSM und Basis-DLM).\nDie violetten Balken zeigen die Übereinstimmung zwischen den beiden Datensätzen und visualisieren die ähnlichen und unterschiedlichen Attribute in Anzahl und Prozent.\nIn der gewählten Region existiert das Attribut ","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"key":"YLnRDJ0ZyN"},{"type":"emphasis","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"children":[{"type":"text","value":"Name","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"key":"Z9dNzpfdKD"}],"key":"BlTeWNt2AN"},{"type":"text","value":" sowohl in OSM- als auch in DLM-Daten größtenteils, wobei es in OSM etwas kompletter scheint. Außerdem wird deutlich, dass das Attribut zwischen den Datensätzen eine hohe Übereinstimmung aufweist. Generell lassen sich anhand der Übereinstimmung nicht direkt Rückschlüsse auf die Datenqualität schließen. Häufige Unterschiede im Attribut ","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"key":"E6sdpcaq1X"},{"type":"emphasis","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"children":[{"type":"text","value":"Straßenspuren","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"key":"OlLdW08Z9a"}],"key":"p9S9fJWGZ7"},{"type":"text","value":" sind beispielsweise stark durch unterschiedliche Kartierungsregeln geprägt.","position":{"start":{"line":80,"column":1},"end":{"line":80,"column":1}},"key":"HOvnpd19yq"}],"key":"cOYam7HIGt"},{"type":"div","children":[{"type":"image","url":"/oqapi-jupyter-book/build/Road_accuracy_name_H-2b28acdc823be8ffd38913cdb983526a.png","width":600,"key":"Qw4xdxQAAf","urlSource":"../abbildungen/Road_accuracy_name_HD.png"}],"key":"rHdOZ7c3g1"},{"type":"paragraph","position":{"start":{"line":89,"column":1},"end":{"line":91,"column":1}},"children":[{"type":"text","value":"In dieser Beispielabbildung wurde die Übereinstimmung aller Attribut überprüft.\nEs ist zu sehen, dass bei fast allen Straßen nicht alle Attribute gesetzt sind. Einige Straßen aus OSM weisen alle Attribute auf. Da es keine Straßen gibt, in denen alle Attribute in beiden Datensätzen vorhanden sind, wird das rechte Balkendiagramm mit der Übereinstimmung der Attribute nicht angezeigt.\nIn jedem Bundesland wird mindestens ein Attribut in der Regel nicht erfasst, daher gibt es im DLM kaum bis keine Straßen, die alle Attribute aufweist, daher kann mit dieser Auswahl hauptsächlich überprüft werden, wie viele OSM-Straßen alle Attribute aufweisen.","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"key":"DSGxIbJ98n"}],"key":"kkbo0vcJFU"},{"type":"div","children":[{"type":"image","url":"/oqapi-jupyter-book/build/straßen_thematisch_n-dba07156715393971ccd5a896a018b9b.png","width":600,"key":"gHvRYcapk9","urlSource":"../abbildungen/straßen_thematisch_nicht_in_beiden.png"}],"key":"N9Bnj8kCzV"},{"type":"heading","depth":2,"position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"children":[{"type":"text","value":"Limitierungen","position":{"start":{"line":97,"column":1},"end":{"line":97,"column":1}},"key":"SWVQ4XV6Lo"}],"identifier":"limitierungen","label":"Limitierungen","html_id":"limitierungen","implicit":true,"key":"qwPmUuyTsI"},{"type":"paragraph","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"children":[{"type":"text","value":"Bekannte Limitierung sind:","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"F9SFRgC7Bl"}],"key":"ZQTCSeJvy0"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":100,"column":1},"end":{"line":105,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":100,"column":1},"end":{"line":100,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Fußgängerstraßen wurden nicht zugewiesen","position":{"start":{"line":100,"column":1},"end":{"line":100,"column":1}},"key":"IhlYWqphzE"}],"key":"RUEau4kT3D"}],"key":"PIAwluy7dk"},{"type":"listItem","spread":true,"position":{"start":{"line":101,"column":1},"end":{"line":101,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Autobahnen werden in den beiden Datensätzen unterschiedlich dargestellt. Im DLM wird jede Spur als eigene Fahrbahnachse eingetragen und die Mittellinie des gesamten Abschnitt ebenfalls als eine Fahrbahnachse. In OSM wird dies oft als eine Straße pro Fahrtrichtung kartiert. Die Anzahl an Spuren wird als Attribut hinzugefügt","position":{"start":{"line":101,"column":1},"end":{"line":101,"column":1}},"key":"X2oWo9q14v"}],"key":"Z2OT9SfM1f"}],"key":"wZu0zgtmuB"},{"type":"listItem","spread":true,"position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"ebenfalls kann es vorkommen, dass DLm-Straßensegmente fälschlicherweise Bahntrassen zugewiesen werden, wenn sich diese zwischen zwei Fahrbahnen befindet","position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"key":"p1qxwfd44C"}],"key":"OURjsOyUCB"}],"key":"XHtuIDsFYe"},{"type":"listItem","spread":true,"position":{"start":{"line":103,"column":1},"end":{"line":105,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"durch die oben beschriebene Annahme bei mehreren zugewiesenen OSM-Straßensegmente auf ein DLM-Straßensegment wird ein Teil der Straßenlänge einer anderen OSM-Straße zugewiesen","position":{"start":{"line":103,"column":1},"end":{"line":103,"column":1}},"key":"TvI6Q4oS26"}],"key":"a5IlXo2dtC"}],"key":"HLvPz46nJj"}],"key":"OVc5M0EgH4"},{"type":"heading","depth":3,"position":{"start":{"line":106,"column":1},"end":{"line":106,"column":1}},"children":[{"type":"text","value":"Referenzen","position":{"start":{"line":106,"column":1},"end":{"line":106,"column":1}},"key":"VJ5AV5JzsT"}],"identifier":"referenzen","label":"Referenzen","html_id":"referenzen","implicit":true,"key":"udOgznk3Aj"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"A. Wöltche, “Open source map matching with Markov decision processes: A new method and a detailed benchmark with existing approaches”, Transactions in GIS, vol. 27, no. 7, pp. 1959–1991, Oct. 2023, doi: ","position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"key":"spOXksA8Mo"},{"type":"cite","url":"https://onlinelibrary.wiley.com/doi/full/10.1111/tgis.13107","position":{"start":{"line":108,"column":1},"end":{"line":108,"column":1}},"children":[{"type":"text","value":"Wöltche (2023)","key":"nBbLupdkuX"}],"kind":"narrative","label":"W_ltche_